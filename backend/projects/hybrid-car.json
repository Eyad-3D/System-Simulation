        {
          "id": "el-hcu",
          "componentDefId": "signal.script",
          "label": "Hybrid Control Unit",
          "position": {
            "x": 330,
            "y": 40
          },
          "parameterOverrides": {
            "code": "def step(t, dt, inputs, state, params):\n    # P2 hybrid supervisory control (edit freely, applies on next run):\n    # engine on/off with SOC hysteresis, clutch above crawl speed,\n    # load-point shifting charges the battery while cruising.\n    soc = inputs.get('soc', 60.0)\n    v = inputs.get('speed', 0.0)\n    trac = inputs.get('traction', 0.0)\n    on = state.get('on', 0.0)\n    if on:\n        if soc > 62.0 and trac < 0.55:\n            on = 0.0\n    else:\n        if soc < 48.0 or trac > 0.85:\n            on = 1.0\n    state['on'] = on\n    clutch = 1.0 if (on and v > 15.0) else 0.0\n    throttle = clamp(trac + 0.25, 0.0, 1.0) if clutch > 0.5 else (0.3 if on else 0.0)\n    motor = trac if clutch < 0.5 else clamp(trac - 0.3, -1.0, 0.3)\n    gear = 1.0\n    for g, up in ((2, 20), (3, 35), (4, 55), (5, 75), (6, 95)):\n        if v > up:\n            gear = float(g)\n    return {'motor_cmd': motor, 'throttle': throttle, 'engine_on': on,\n            'clutch_cmd': clutch, 'gear': gear}\n"
          },
